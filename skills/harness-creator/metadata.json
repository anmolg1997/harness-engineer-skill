{
  "name": "harness-creator",
  "version": "1.1.0",
  "description": "Harness engineering for AI coding agents — five subsystems, the evidence-before-done invariant gate, session continuity, verification workflows, scope control, clean-state guards, lifecycle management.",
  "license": "MIT",
  "author": "Anmol Jaiswal",
  "repository": "https://github.com/walkinglabs/learn-harness-engineering",
  "derivedFrom": "walkinglabs/learn-harness-engineering (MIT)",
  "languages": ["en"],
  "compatibility": {
    "minCliVersion": "0.1.0",
    "agents": [
      "claude-code",
      "codex-cli",
      "cursor",
      "windsurf",
      "generic"
    ]
  },
  "entryPoint": "SKILL.md",
  "references": [
    "references/memory-persistence-pattern.md",
    "references/context-engineering-pattern.md",
    "references/skill-runtime-pattern.md",
    "references/tool-registry-pattern.md",
    "references/multi-agent-pattern.md",
    "references/lifecycle-bootstrap-pattern.md",
    "references/gotchas.md"
  ],
  "triggers": [
    "harness engineering",
    "agent reliability",
    "session continuity",
    "memory persistence",
    "verification workflow",
    "evidence before done",
    "premature completion",
    "scope control",
    "work in progress limit",
    "clean state",
    "lifecycle management",
    "AGENTS.md",
    "CLAUDE.md",
    "feature tracking",
    "feature list invariants",
    "session handoff",
    "multi-agent coordination",
    "context engineering",
    "tool safety",
    "permission pipeline"
  ],
  "bundled": {
    "scripts": [
      "scripts/create-harness.mjs",
      "scripts/recognize.mjs",
      "scripts/validate-harness.mjs",
      "scripts/validate-feature-list.mjs",
      "scripts/cleanup-scanner.mjs",
      "scripts/check-architecture.mjs",
      "scripts/render-assessment-html.mjs",
      "scripts/run-benchmark.mjs",
      "scripts/lib/harness-utils.mjs"
    ],
    "assets": [
      "ci/github-actions.yml",
      "ci/pre-commit"
    ],
    "templates": [
      "templates/agents.md",
      "templates/feature-list.json",
      "templates/feature-list.schema.json",
      "templates/init.sh",
      "templates/progress.md",
      "templates/session-handoff.md",
      "templates/clean-state-checklist.md",
      "templates/evaluator-rubric.md"
    ]
  }
}
